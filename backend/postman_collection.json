{
  "info": {
    "name": "Norn Backend API",
    "description": "Norn Health Monitoring API - Verification and Validation tests. Open each request and check the 'Tests' tab to see scripts.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "event": [
    {
      "listen": "test",
      "script": {
        "type": "text/javascript",
        "exec": [
          "// Collection-level test (runs after each request). Request-specific tests are in each request's Tests tab."
        ]
      }
    }
  ],
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:8000"
    },
    {
      "key": "user_id",
      "value": "0b8baf9c-dcfa-4d11-93d5-a08ce06a3d61"
    },
    {
      "key": "alert_id",
      "value": "",
      "description": "Set from GET Alerts response (e.g. first alert id) for PATCH requests"
    }
  ],
  "item": [
    {
      "name": "Root",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/",
        "description": "API root - version and status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "pm.test('Response is JSON', function() { pm.response.to.be.json; });",
              "const body = pm.response.json();",
              "pm.test('Has message', function() { pm.expect(body).to.have.property('message'); });",
              "pm.test('Has version', function() { pm.expect(body).to.have.property('version'); });",
              "pm.test('Has status running', function() { pm.expect(body.status).to.eql('running'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Health (simple)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/health",
        "description": "Simple health check"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Has status healthy', function() { pm.expect(body).to.have.property('status'); pm.expect(body.status).to.eql('healthy'); });",
              "pm.test('Has environment', function() { pm.expect(body).to.have.property('environment'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "Health status (detailed)",
      "request": {
        "method": "GET",
        "header": [],
        "url": "{{base_url}}/api/v1/health/status",
        "description": "Backend + Supabase status"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Has backend object', function() { pm.expect(body).to.have.property('backend'); pm.expect(body.backend.status).to.eql('healthy'); });",
              "pm.test('Has supabase object', function() { pm.expect(body).to.have.property('supabase'); pm.expect(body.supabase).to.have.property('url'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "POST Activity event",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"esp32-imu-001\",\n  \"timestamp\": 123456,\n  \"activity\": \"w\"\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sensor/activity?user_id={{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "sensor",
            "activity"
          ],
          "query": [
            {
              "key": "user_id",
              "value": "{{user_id}}",
              "description": "Optional"
            }
          ]
        },
        "description": "Receive activity change from ESP32. Activity: w, st, si, r, f, af, nf"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Has activity in response', function() { pm.expect(body).to.have.property('activity'); });",
              "pm.test('Message indicates received', function() { pm.expect(body.message).to.include('Activity'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Activity statistics (today)",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/sensor/activity/statistics?period=today&user_id={{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "sensor",
            "activity",
            "statistics"
          ],
          "query": [
            {
              "key": "period",
              "value": "today",
              "description": "Required: today, 7d, or 30d"
            },
            {
              "key": "user_id",
              "value": "{{user_id}}",
              "description": "Optional"
            }
          ]
        },
        "description": "Get activity stats for today"
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Has statistics object', function() { pm.expect(body).to.have.property('statistics'); });",
              "const stats = body.statistics;",
              "pm.test('Statistics has period', function() { pm.expect(stats).to.have.property('period'); });",
              "pm.test('Statistics has by_activity', function() { pm.expect(stats).to.have.property('by_activity'); });",
              "pm.test('Statistics has events array', function() { pm.expect(stats).to.have.property('events'); pm.expect(stats.events).to.be.an('array'); });",
              "pm.test('Period is today', function() { pm.expect(stats.period).to.eql('today'); });"
            ]
          }
        }
      ]
    },
