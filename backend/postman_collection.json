    {
      "name": "POST IMU alert (critical)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"esp32-imu-001\",\n  \"timestamp\": 45678,\n  \"prediction\": \"f\",\n  \"prediction_idx\": 1\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sensor/imu/alert?user_id={{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "sensor",
            "imu",
            "alert"
          ],
          "query": [
            {
              "key": "user_id",
              "value": "{{user_id}}",
              "description": "Optional"
            }
          ]
        },
        "description": "IMU critical alert (f, af, nf). Creates alert in DB."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Alert was created', function() { pm.expect(body.alert_created).to.be.true; });",
              "pm.test('Has alert_type', function() { pm.expect(body).to.have.property('alert_type'); });",
              "pm.test('Has severity', function() { pm.expect(body).to.have.property('severity'); });",
              "pm.test('Critical prediction creates fall alert', function() { pm.expect(body.alert_type).to.eql('fall'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "POST IMU alert (non-critical)",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"device_id\": \"esp32-imu-001\",\n  \"timestamp\": 45678,\n  \"prediction\": \"st\",\n  \"prediction_idx\": 5\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/sensor/imu/alert?user_id={{user_id}}",
          "host": [
            "{{base_url}}"
          ],
          "path": [
            "api",
            "v1",
            "sensor",
            "imu",
            "alert"
          ],
          "query": [
            {
              "key": "user_id",
              "value": "{{user_id}}"
            }
          ]
        },
        "description": "Non-critical prediction (st, si, w, r). No alert stored."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('No alert created for non-critical', function() { pm.expect(body.alert_created).to.be.false; });",
              "pm.test('Message indicates logged', function() { pm.expect(body.message).to.include('logged'); });"
            ]
          }
        }
      ]
    },
    {
      "name": "GET Alerts",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/api/v1/alerts?user_id={{user_id}}&limit=50",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alerts"],
          "query": [
            { "key": "user_id", "value": "{{user_id}}" },
            { "key": "limit", "value": "50" },
            { "key": "is_read", "value": "", "disabled": true, "description": "Optional: true/false" },
            { "key": "is_resolved", "value": "", "disabled": true, "description": "Optional: true/false" }
          ]
        },
        "description": "List alerts for user. Optionally filter by is_read, is_resolved. Save an alert id to alert_id variable for PATCH."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Has alerts array', function() { pm.expect(body).to.have.property('alerts'); pm.expect(body.alerts).to.be.an('array'); });",
              "pm.test('Has count', function() { pm.expect(body).to.have.property('count'); });",
              "if (body.alerts && body.alerts.length > 0) { pm.collectionVariables.set('alert_id', body.alerts[0].id); }"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH Alert mark read",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"is_read\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/alerts/{{alert_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alerts", "{{alert_id}}"]
        },
        "description": "Set is_read=true for an alert. Use alert_id from GET Alerts or set collection variable alert_id."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Has updated alert', function() { pm.expect(body).to.have.property('alert'); });",
              "pm.test('Alert is_read is true', function() { pm.expect(body.alert.is_read).to.be.true; });"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH Alert mark resolved",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"is_resolved\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/alerts/{{alert_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alerts", "{{alert_id}}"]
        },
        "description": "Set is_resolved=true for an alert. Backend also sets resolved_at. Use alert_id from GET Alerts."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Has updated alert', function() { pm.expect(body).to.have.property('alert'); });",
              "pm.test('Alert is_resolved is true', function() { pm.expect(body.alert.is_resolved).to.be.true; });"
            ]
          }
        }
      ]
    },
    {
      "name": "PATCH Alert mark read and resolved",
      "request": {
        "method": "PATCH",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"is_read\": true,\n  \"is_resolved\": true\n}"
        },
        "url": {
          "raw": "{{base_url}}/api/v1/alerts/{{alert_id}}",
          "host": ["{{base_url}}"],
          "path": ["api", "v1", "alerts", "{{alert_id}}"]
        },
        "description": "Set both is_read and is_resolved to true in one call."
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('Status code is 200', function() { pm.response.to.have.status(200); });",
              "const body = pm.response.json();",
              "pm.test('Response status is success', function() { pm.expect(body.status).to.eql('success'); });",
              "pm.test('Alert is_read and is_resolved true', function() { pm.expect(body.alert.is_read).to.be.true; pm.expect(body.alert.is_resolved).to.be.true; });"
            ]
          }
        }
      ]
    }
  ]
